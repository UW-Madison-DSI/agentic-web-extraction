# Provider credentials — any OpenAI-compatible endpoint.
# Defaults below target the UW-Madison DSI Spark gateway; swap for OpenAI
# (https://api.openai.com/v1/) or another endpoint as needed.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://spark.dsi.wisc.edu

# Models — point these at models your key can actually access.
# Query the endpoint's models with: curl $OPENAI_BASE_URL/v1/models -H "Authorization: Bearer $OPENAI_API_KEY"
AWE_MODEL_EXTRACT=gemma-4-26b-a4b-it
AWE_MODEL_SCREEN=gemma-4-26b-a4b-it

# Traversal budget (the only traversal knob in v0)
AWE_MAX_FETCHES=10

# Optional
# AWE_STOP_ON_FIRST_MATCH=false   # true = return on first match; false = gather all + merge
# AWE_OFF_DOMAIN_WEIGHT=1.0       # off-domain link score weight: 1.0 = full weight / no preference,
#                                 # < 1.0 = soft same-domain nudge (not a filter), 0.0 = strongest
# AWE_PROVIDER=openai
# AWE_NORMALIZE=true
# AWE_FOLLOW_PDF=true
# AWE_HTTP_CACHE=data/http_cache.sqlite   # empty = in-memory

# ─────────────────────────────────────────────────────────────────────────────
# Provider credentials (OPENAI_*, read un-prefixed so a standard OpenAI env works)
# ─────────────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint. Defaults below target the UW-Madison DSI Spark
# gateway; swap for OpenAI (https://api.openai.com/v1/) or another endpoint.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://spark.dsi.wisc.edu
# OPENAI_BASE_URL is optional — omit to use OpenAI's default (https://api.openai.com/v1/).

# ─────────────────────────────────────────────────────────────────────────────
# Models
# ─────────────────────────────────────────────────────────────────────────────
# Point these at models your key can actually access. Query the endpoint with:
#   curl $OPENAI_BASE_URL/v1/models -H "Authorization: Bearer $OPENAI_API_KEY"
# Extraction is the stronger/costlier call (fills the caller's schema); screen +
# link-scoring are cheap comparison calls and share one (smaller) model.
AWE_MODEL_EXTRACT=gemma-4-26b-a4b-it   # default: gpt-5.5
AWE_MODEL_SCREEN=gemma-4-26b-a4b-it    # default: gpt-5.4-mini

# ─────────────────────────────────────────────────────────────────────────────
# Traversal
# ─────────────────────────────────────────────────────────────────────────────
# Fetch budget: max readable pages the crawl spends LLM calls on. The primary
# (and, deliberately, near-only) traversal knob in v0.
AWE_MAX_FETCHES=10

# ─────────────────────────────────────────────────────────────────────────────
# Optional knobs (shown with their defaults; uncomment to override)
# ─────────────────────────────────────────────────────────────────────────────
# AWE_PROVIDER=openai                     # provider backend ("openai" is the only v0 impl)
# AWE_STOP_ON_FIRST_MATCH=false           # true = return on first match; false = gather all + merge
# AWE_PREFER_SEED_DOMAIN=false            # true = tell the LLM the seed/page URL + an on-domain signal and
#                                         # ask it to disfavor off-domain pages/links (a nudge, not a filter)
# AWE_NORMALIZE=true                      # convert fetched HTML to Markdown before the LLM sees it (cuts tokens)
# AWE_FOLLOW_PDF=true                     # fetch and read linked PDFs as page content
# AWE_HTTP_CACHE=data/http_cache.sqlite   # on-disk HTTP response cache; empty = in-memory
# AWE_LOG_FILE=awe.log                    # append timestamped progress lines to this file (empty/unset = off; always to stderr regardless)
